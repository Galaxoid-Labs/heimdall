# ── Generated by the heimdall CLI ───────────────────────────────────────────
# Asset map (#load'd into the binary; regenerated by `heimdall build` / `embed`)
assets_gen.odin
**/assets_gen.odin
# Typed bindings (optional; regenerated by `heimdall generate-bindings`)
**/bindings.d.ts

# ── Build outputs ────────────────────────────────────────────────────────────
# The CLI binary. NOTE: do NOT add `/heimdall` here — that's the framework
# package directory and must be committed.
/heimdall-cli
/heimdall.bin
# Compiled examples (Odin emits extensionless binaries, usually at the repo root)
/hello
/_probe*
# macOS bundles / installers
*.app/
*.dmg
# Windows build outputs (.exe binaries, debug info, WebView2 user-data dirs
# created next to a running .exe, and `heimdall bundle` zips). The vendored
# WebView2LoaderStatic.lib is *.lib and stays committed.
*.exe
*.pdb
*.WebView2/
# Frontend build output (embedded at build time)
/dist/
**/web/dist/

# ── Docs site (VitePress) ────────────────────────────────────────────────────
node_modules/
docs/.vitepress/dist/
docs/.vitepress/cache/
# Keep bun.lock committed (CI uses --frozen-lockfile).

# ── Vendored ─────────────────────────────────────────────────────────────────
# The Windows WebView2 loader (heimdall/webview2/WebView2LoaderStatic.lib) is a
# committed *.lib — only object files are ignored.
*.o

# ── OS / editor cruft ────────────────────────────────────────────────────────
.DS_Store
*.swp
.vscode/
.idea/
